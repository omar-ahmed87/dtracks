PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Auth
JWT_SECRET=
JWT_ISSUER=etracks
JWT_AUDIENCE=etracks-users
JWT_EXPIRATION=7d
AUTH_COOKIE_NAME=authToken

# SMS / WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Gmail (easiest for email codes) — use App Password from Google Account
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Or generic SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# CORS
CORS_WHITELIST=http://localhost:3000
