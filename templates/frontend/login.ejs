<section class="register-section">
  <div class="register-card fade-in-up">
    <div class="register-header">
      <div class="register-icon">
        <span class="material-symbols-rounded">login</span>
      </div>
      <h2 data-i18n="login_welcome">Welcome Back</h2>
      <p data-i18n="login_subtitle">Sign in to continue your learning journey.</p>
    </div>

    <form id="login-form" class="form-container" autocomplete="off">
      <input type="text" style="display:none;" aria-hidden="true" />
      <input type="password" style="display:none;" aria-hidden="true" />
      
      <div class="form-group">
        <label for="u_email" class="form-label" data-i18n="label_email">Email Address</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">mail</span>
          <input type="email" id="u_email" name="u_email" class="form-control with-icon" 
                 placeholder="you@example.com" required 
                 readonly onfocus="this.removeAttribute('readonly');" 
                 autocomplete="new-password" />
        </div>
      </div>

      <div class="form-group">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
          <label for="u_pass" class="form-label" style="margin-bottom: 0" data-i18n="label_password">Password</label>
          <a href="/forgot-password" style="font-size: 13px; color: var(--primary); font-weight: 600; text-decoration: none;" data-i18n="label_forgot_password">Forgot?</a>
        </div>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">lock</span>
          <input type="password" id="u_pass" name="u_pass" class="form-control with-icon" 
                 required readonly onfocus="this.removeAttribute('readonly');" 
                 autocomplete="new-password" />
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-glow w-100 mt-4">
        <span data-i18n="btn_login_submit">Log In</span>
        <span class="material-symbols-rounded">arrow_right_alt</span>
      </button>
    </form>

    <div class="form-footer" style="margin-top: 24px; text-align: center; position: relative; z-index: 20;">
      <p style="font-size: 14px; color: var(--text-muted);">
        Don't have an account? 
        <a href="/signup" style="color: var(--primary); font-weight: 600; text-decoration: none; pointer-events: auto;">Sign Up</a>
      </p>
    </div>
  </div>
</section>