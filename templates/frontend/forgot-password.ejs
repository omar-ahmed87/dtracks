<section class="register-section forgot-password-section">
  <div class="register-card fade-in-up forgot-card">
    <div class="register-header">
      <div class="register-icon">
        <span class="material-symbols-rounded">lock_reset</span>
      </div>
      <h2 data-i18n="forgot_title">Reset your password</h2>
      <p data-i18n="forgot_subtitle">Choose how you want to recover your account.</p>
    </div>

    <div id="forgot-inline-error" class="form-inline-error hidden" role="alert"></div>
    <div id="forgot-inline-success" class="form-inline-success hidden" role="status"></div>

    <form id="forgot-step-method" class="form-container">
      <div class="form-group">
        <span class="form-label" data-i18n="forgot_channel">Recovery method</span>
        <div class="recovery-method-grid recovery-method-grid--two" role="radiogroup" aria-label="Recovery method">
          <label class="recovery-method-card">
            <input type="radio" name="channel" value="sms" checked />
            <span class="recovery-method-icon material-symbols-rounded">sms</span>
            <span class="recovery-method-label">SMS</span>
          </label>
          <label class="recovery-method-card">
            <input type="radio" name="channel" value="email" />
            <span class="recovery-method-icon material-symbols-rounded">mail</span>
            <span class="recovery-method-label">Email</span>
          </label>
        </div>
      </div>

      <div id="forgot-contact-wrap" class="form-group">
        <label for="forgot-contact" class="form-label" id="forgot-contact-label" data-i18n="label_phone">Phone number</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon" id="forgot-contact-icon">phone</span>
          <input type="tel" id="forgot-contact" name="contact" class="form-control with-icon" placeholder="+20 1XX XXX XXXX" required autocomplete="tel" />
        </div>
        <p class="field-hint" id="forgot-contact-hint" data-i18n="forgot_phone_hint">Enter your phone number to receive a verification code.</p>
      </div>

      <button type="submit" class="btn btn-primary btn-glow w-100 mt-4">
        <span data-i18n="forgot_send_code">Send verification code</span>
      </button>
    </form>

    <form id="forgot-step-code" class="form-container hidden">
      <p class="forgot-hint" data-i18n="forgot_code_hint">Enter the 6-digit code we sent you.</p>
      <div class="form-group">
        <label for="reset-code" class="form-label" data-i18n="forgot_code_label">Verification code</label>
        <input type="text" id="reset-code" class="form-control code-input" inputmode="numeric" maxlength="6" pattern="[0-9]{6}" required placeholder="000000" />
      </div>
      <button type="button" class="btn btn-outline w-100 mb-3" id="forgot-resend" data-i18n="forgot_resend">Resend code</button>
      <button type="submit" class="btn btn-primary btn-glow w-100" data-i18n="forgot_verify">Continue</button>
    </form>

    <form id="forgot-step-newpass" class="form-container hidden">
      <div class="form-group">
        <label for="reset-new-pass" class="form-label" data-i18n="label_new_password">New password</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">lock</span>
          <input type="password" id="reset-new-pass" class="form-control with-icon" minlength="8" required autocomplete="new-password" />
        </div>
      </div>
      <div class="form-group">
        <label for="reset-confirm-pass" class="form-label" data-i18n="label_confirm_password">Confirm password</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">lock</span>
          <input type="password" id="reset-confirm-pass" class="form-control with-icon" minlength="8" required autocomplete="new-password" />
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-glow w-100 mt-4" data-i18n="forgot_save">Update password</button>
    </form>

    <div class="form-footer" style="margin-top: 24px; text-align: center;">
      <a href="/login" class="link-primary" data-i18n="btn_back_login">Back to login</a>
    </div>
  </div>
</section>
