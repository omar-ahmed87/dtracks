<style>
  /* =============================================
     CLASSROOM PAGE - LAYOUT
     ============================================= */

  /* Page wrapper - starts below navbar */
  .classroom-page {
    min-height: calc(100vh - 80px);
    display: flex;
    background: var(--bg-color);
    font-family: 'Outfit', sans-serif;
    color: var(--text-main);
    margin-top: 80px;
  }
  [dir="rtl"] .classroom-page {
    font-family: 'Cairo', sans-serif;
  }

  /* Flex container holding sidebar + main */
  .lms-container {
    display: flex;
    width: 100%;
    position: relative;
    align-items: flex-start;
  }

  /* ── SIDEBAR (fixed, always on left) ── */
  .lms-sidebar {
    position: fixed;
    top: 80px;
    left: 0;
    width: 280px;
    height: calc(100vh - 80px);
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-right: 1px solid var(--glass-border);
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    overflow-x: hidden;
    z-index: 200;
    box-sizing: border-box;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    /* Prevent Lenis/transform from breaking fixed positioning */
    transform: translateZ(0);
    will-change: transform;
  }

  /* ── MAIN CONTENT (offset by sidebar) ── */
  .lms-main {
    flex: 1;
    margin-left: 280px;
    width: calc(100% - 280px);
    min-height: calc(100vh - 80px);
    padding: 40px 30px 30px;
    box-sizing: border-box;
    overflow-x: hidden;
    background: var(--bg-color);
  }

  /* ── RTL ── */
  [dir="rtl"] .lms-sidebar {
    left: auto;
    right: 0;
    border-right: none;
    border-left: 1px solid var(--glass-border);
  }
  [dir="rtl"] .lms-main {
    margin-left: 0;
    margin-right: 280px;
  }

  /* ── MOBILE (≤ 991px) ── */
  @media (max-width: 991px) {
    /* Hide sidebar off-screen */
    .lms-sidebar {
      left: -280px;
      background: var(--bg-color);
      box-shadow: 4px 0 24px rgba(0,0,0,0.15);
      z-index: 300;
    }
    .lms-sidebar.open {
      left: 0;
    }

    /* Main takes full width, padded below mobile bar */
    .lms-main {
      margin-left: 0;
      width: 100%;
      padding: 20px 16px;
      padding-top: 72px;
    }

    /* RTL mobile */
    [dir="rtl"] .lms-sidebar {
      left: auto;
      right: -280px;
    }
    [dir="rtl"] .lms-sidebar.open {
      right: 0;
      left: auto;
    }
    [dir="rtl"] .lms-main {
      margin-right: 0;
    }
  }

  /* ── MOBILE TOP BAR (hamburger) ── */
  .lms-mobile-bar {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    z-index: 199;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--glass-border);
    padding: 10px 20px;
    justify-content: space-between;
    align-items: center;
  }
  @media (max-width: 991px) {
    .lms-mobile-bar {
      display: flex;
    }
  }

  /* Profile Card in Sidebar */
  .sidebar-profile {
    text-align: center;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: 12px;
  }
  .sidebar-profile .avatar-wrapper {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px auto;
    box-shadow: 0 8px 16px rgba(79, 70, 229, 0.2);
  }
  .sidebar-profile .avatar-wrapper .material-symbols-rounded {
    font-size: 40px;
    color: var(--white);
  }
  .sidebar-profile h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
  }
  .sidebar-profile p {
    font-size: 12px;
    color: var(--text-muted);
    margin: 4px 0 0 0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  /* Active Sidebar items */
  .lms-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .lms-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    transition: all 0.2s ease;
    position: relative;
  }
  [dir="rtl"] .lms-nav-link {
    text-align: right;
  }
  .lms-nav-link:hover,
  .lms-nav-link.active {
    color: var(--primary);
    background: rgba(79, 70, 229, 0.06);
  }
  .lms-nav-link.active {
    background: rgba(79, 70, 229, 0.1);
    box-shadow: inset 3px 0 0 var(--primary);
  }
  [dir="rtl"] .lms-nav-link.active {
    box-shadow: inset -3px 0 0 var(--primary);
  }
  .lms-nav-link .material-symbols-rounded {
    font-size: 20px;
    transition: transform 0.2s ease;
  }
  .lms-nav-link:hover .material-symbols-rounded {
    transform: scale(1.15);
  }

  /* Main content area */
  @media (max-width: 768px) {
    #dashboard-shortcuts-row {
      grid-template-columns: 1fr !important;
    }
    #continue-learning-widget {
      flex-direction: column !important;
      align-items: flex-start !important;
    }
    #btn-continue-course-home {
      width: 100%;
    }
    .empty-state-actions .btn {
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
    }
  }

  /* Tabs wrapper */
  .tab-panel {
    display: none;
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    
  }
  .tab-panel.active {
    display: block;
  }

  /* Premium Dashboard Welcome Banner */
  .dashboard-welcome-banner {
    position: relative;
    background: linear-gradient(135deg, #1e1b4b, #311042);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--white);
    padding: 36px;
    border-radius: var(--radius-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    box-shadow: var(--shadow-lg);
    margin-bottom: 32px;
    overflow: hidden;
  }
  .dashboard-welcome-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .dashboard-welcome-banner h1 {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 8px 0;
    letter-spacing: -0.5px;
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .dashboard-welcome-banner p {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  /* Streak / XP Badges */
  .stats-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .stat-badge {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 20px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    color: var(--white);
    box-shadow: var(--shadow-sm);
  }

  /* Course Cards styling */
  .active-tracks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  .course-progress-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .course-progress-card:hover {
    transform: translateY(-5px);
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }
  .course-progress-card .course-icon-box {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: rgba(79, 70, 229, 0.1);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .course-progress-card .course-icon-box .material-symbols-rounded {
    font-size: 24px;
  }
  .course-progress-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin: 0;
    color: var(--text-main);
  }
  .course-progress-card p {
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Progress Bar styling */
  .progress-wrapper {
    margin-top: auto;
  }
  .progress-info {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .progress-info .pct {
    color: var(--primary);
  }
  .progress-track-bg {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 100px;
    overflow: hidden;
  }
  .progress-track-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    border-radius: 100px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ────────────────────────────────────────────────────────────────
     STUNNING INTERACTIVE CLASSROOM VIDEO PLAYER LAYOUT
     ──────────────────────────────────────────────────────────────── */
  .classroom-shell {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 1200px) {
    .classroom-shell {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .lms-main-course {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .video-viewport-card {
    background: #0d0c15;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .lms-video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    width: 100%;
  }
  .lms-video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Video player controls bar */
  .video-controls-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    padding: 16px 24px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid var(--glass-border);
  }
  .speed-selector-group {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .speed-selector-group label {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-muted);
  }
  .speed-custom-select {
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--glass-border);
    background: var(--bg-light);
    color: var(--text-main);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .speed-custom-select:focus {
    border-color: var(--primary);
  }

  /* Course Video Description and Metadata */
  .course-player-info {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }
  .course-player-info h3 {
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 10px 0;
    color: var(--text-main);
  }
  .course-player-info p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Sidebar widgets tabbed container */
  .lms-player-sidebar {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 640px;
    position: sticky;
    top: 112px;
  }
  @media (max-width: 1200px) {
    .lms-player-sidebar {
      position: static;
      height: 500px;
    }
  }

  /* Sidebar Tab Bar */
  .player-sidebar-tabs {
    display: flex;
    border-bottom: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.01);
  }
  .sidebar-tab-btn {
    flex: 1;
    padding: 16px 8px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 2px solid transparent;
    text-align: center;
  }
  .sidebar-tab-btn:hover {
    color: var(--text-main);
  }
  .sidebar-tab-btn.active {
    color: var(--primary);
    border-bottom-color: var(--primary);
    background: rgba(79, 70, 229, 0.04);
  }

  /* Tab panels wrapper inside sidebar */
  .player-sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
  }
  .sidebar-panel {
    display: none;
  }
  .sidebar-panel.active {
    display: block;
  }

  /* Accordion styles inside syllabus */
  .lms-module-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.02);
    border: none;
    border-bottom: 1px solid var(--glass-border);
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }
  [dir="rtl"] .lms-module-header {
    text-align: right;
  }
  .lms-module-header:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .lms-module-header strong {
    font-size: 14px;
    color: var(--text-main);
  }
  .lms-module-header .material-symbols-rounded {
    color: var(--text-muted);
    transition: transform 0.2s ease;
  }
  .lms-module.open .lms-module-header .material-symbols-rounded {
    transform: rotate(180deg);
  }

  .lms-lesson-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 12px 16px;
    border: none;
    background: transparent;
    border-bottom: 1px solid var(--glass-border);
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  [dir="rtl"] .lms-lesson-row {
    text-align: right;
  }
  .lms-lesson-row:hover {
    background: rgba(79, 70, 229, 0.04);
  }
  .lms-lesson-row.completed {
    background: rgba(16, 185, 129, 0.02);
  }
  .lms-lesson-row.completed:hover {
    background: rgba(16, 185, 129, 0.04);
  }
  .lms-lesson-row .lesson-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-main);
  }
  .lms-lesson-row .lesson-dur {
    font-size: 11px;
    background: rgba(255, 255, 255, 0.04);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--text-muted);
  }

  /* Note Rows inside sidepanel */
  .note-list-box {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .note-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-sm);
    padding: 12px;
    position: relative;
  }
  .note-item .time-anchor {
    font-size: 11px;
    font-weight: 700;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 2px 6px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 6px;
  }
  .note-item p {
    font-size: 13px;
    margin: 0;
    color: var(--text-main);
    line-height: 1.5;
  }
  .note-item .btn-delete-note {
    position: absolute;
    top: 10px;
    right: 10px;
    background: transparent;
    border: none;
    color: #ef4444;
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
  }
  [dir="rtl"] .note-item .btn-delete-note {
    right: auto;
    left: 10px;
  }

  /* Downloads list */
  .download-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .download-item-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text-main);
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .download-item-link:hover {
    border-color: var(--primary);
    background: rgba(79, 70, 229, 0.04);
  }
  .download-item-link .icon-side {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .download-item-link .material-symbols-rounded {
    color: var(--primary);
  }

  /* Lesson Module Accordion */
  .lesson-module-card.open .lesson-module-body {
    display: block !important;
  }
  .lesson-module-card.open .module-chevron {
    transform: rotate(180deg);
  }
  .lesson-module-toggle:hover {
    background: rgba(79, 70, 229, 0.04) !important;
  }

  /* Placement test card padding fix for accent stripe */
  .placement-test-card {
    padding-left: 28px !important;
  }
  [dir="rtl"] .placement-test-card {
    padding-left: 24px !important;
    padding-right: 28px !important;
  }
  [dir="rtl"] .placement-test-card > div:first-child {
    left: auto !important;
    right: 0 !important;
  }

  /* Exams panel main padding */
  #panel-exams,
  #panel-notifications {
    animation: fadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lms-notif-badge {
    margin-left: auto;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .lms-notif-badge.hidden {
    display: none;
  }
  [dir="rtl"] .lms-notif-badge {
    margin-left: 0;
    margin-right: auto;
  }
  .notif-card {
    padding: 18px 20px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .notif-card.unread {
    border-color: rgba(79, 70, 229, 0.45);
    box-shadow: 0 0 0 1px rgba(79, 70, 229, 0.12);
  }
  .notif-card:hover {
    border-color: var(--primary);
  }
  .notif-card h4 {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 800;
  }
  .notif-card p {
    margin: 0;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.55;
    white-space: pre-wrap;
  }
  .notif-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
  }
</style>

<div class="lms-mobile-bar hide-desktop">
  <button id="lms-sidebar-toggle" class="btn-icon">
    <span class="material-symbols-rounded">menu</span>
  </button>
  <h2 style="font-size: 18px;" data-i18n="nav_classroom">Classroom</h2>
  <div style="width: 40px;"></div>
</div>

<section class="classroom-page" id="classroom-app">
  <!-- 1. LOADING PANEL -->
  <div id="classroom-loading" class="classroom-loading w-100" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh; gap: 16px;">
    <span class="material-symbols-rounded spinning" style="font-size: 44px; color: var(--primary);">progress_activity</span>
    <p style="font-size: 14px; font-weight: 600; color: var(--text-muted);" data-i18n="loading">Loading dashboard...</p>
  </div>

  <!-- 2. EMPTY STATE (UNSUBSCRIBED) -->
  <div id="classroom-empty" class="classroom-panel classroom-empty-state hidden w-100" style="display: flex; align-items: center; justify-content: center; min-height: 70vh;">
    <div class="empty-state-card reveal-up" style="max-width: 480px; text-align: center; padding: 40px 24px;">
      <span class="material-symbols-rounded empty-icon" style="font-size: 64px; color: var(--text-muted); margin-bottom: 20px;">lock</span>
      <h2 style="font-size: 24px; font-weight: 800; margin-bottom: 12px;" data-i18n="classroom_empty_title">Subscribe to a course</h2>
      <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 24px;" data-i18n="classroom_empty_desc">You need an active course subscription to access lessons, videos, and quizzes.</p>
      <div class="empty-state-actions">
        <a href="/register" class="btn btn-primary btn-lg" style="height: 48px; display: inline-flex; align-items: center; gap: 8px; text-decoration: none;" data-i18n="btn_get_started">Get Started</a>
      </div>
    </div>
  </div>

  <!-- 3. PENDING STATE (AWAITING APPROVAL) -->
