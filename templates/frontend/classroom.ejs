<!-- Classroom tab & panel navigation logic -->
<script>
  document.addEventListener('DOMContentLoaded', () => {

    /* ── 1. Player sidebar tabs (Curriculum / Notes / Downloads) ── */
    const tabBtns = document.querySelectorAll('.sidebar-tab-btn');
    const playerPanels = document.querySelectorAll('.sidebar-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const target = btn.dataset.tab;
        playerPanels.forEach(p => {
          p.classList.remove('active');
          if (p.id === `tabpanel-${target}`) p.classList.add('active');
        });
      });
    });

    /* ── 2. Main LMS sidebar nav (Dashboard / My Courses / Exams) ── */
    const navBtns = document.querySelectorAll('.lms-nav-link');
    const tabPanels = document.querySelectorAll('.tab-panel');

    function switchMainPanel(target) {
      navBtns.forEach(b => b.classList.remove('active'));
      tabPanels.forEach(p => p.classList.remove('active'));

      const activeBtn = document.querySelector(`.lms-nav-link[data-target="${target}"]`);
      const activePanel = document.getElementById(`panel-${target}`);

      if (activeBtn)  activeBtn.classList.add('active');
      if (activePanel) activePanel.classList.add('active');

      /* When switching to Exams, hydrate the course name badge */
      if (target === 'exams') {
        const courseTitle = document.getElementById('continue-course-title');
        const examsBadge  = document.getElementById('exams-course-name');
        if (examsBadge && courseTitle) {
          const name = courseTitle.textContent.trim();
          examsBadge.textContent = (name && name !== 'Loading track...') ? name : 'My Course';
        }
      }
    }

    navBtns.forEach(btn => {
      btn.addEventListener('click', () => switchMainPanel(btn.dataset.target));
    });

    /* ── 3. Lesson module accordion chevron ── */
    document.querySelectorAll('.lesson-module-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const card    = toggle.closest('.lesson-module-card');
        const chevron = toggle.querySelector('.module-chevron');
        const body    = card.querySelector('.lesson-module-body');
        const isOpen  = card.classList.toggle('open');
        if (chevron) chevron.style.transform = isOpen ? 'rotate(180deg)' : '';
        if (body)    body.style.display      = isOpen ? 'block' : 'none';
      });
    });

    /* ── 4. Mobile sidebar toggle handled by classroom.js initLmsNavigation() ── */

  });
</script>


