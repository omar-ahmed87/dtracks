<section class="register-section">
  <div class="register-card fade-in-up">
    <div class="register-header">
      <div class="register-icon" style="background: var(--primary); color: white;">
        <span class="material-symbols-rounded">admin_panel_settings</span>
      </div>
      <h2>Admin Portal</h2>
      <p>Secure access for platform administrators.</p>
    </div>

    <form id="admin-login-form" class="form-container" autocomplete="off">
      <input type="text" style="display:none;" aria-hidden="true" />
      <input type="password" style="display:none;" aria-hidden="true" />

      <div class="form-group">
        <label for="admin-email" class="form-label">Admin Email</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">mail</span>
          <input type="email" id="admin-email" name="email" class="form-control with-icon" 
                 placeholder="admin@etracks.com" required 
                 readonly onfocus="this.removeAttribute('readonly');" 
                 autocomplete="new-password" />
        </div>
      </div>

      <div class="form-group">
        <label for="admin-password" class="form-label">Secure Password</label>
        <div class="input-wrapper">
          <span class="material-symbols-rounded input-icon">lock</span>
          <input type="password" id="admin-password" name="password" class="form-control with-icon" 
                 placeholder="••••••••" required 
                 readonly onfocus="this.removeAttribute('readonly');" 
                 autocomplete="new-password" />
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-glow w-100 mt-4">
        <span>Authenticate</span>
        <span class="material-symbols-rounded">verified_user</span>
      </button>

      <div style="margin-top: 20px; text-align: center;">
        <a href="/" style="font-size: 14px; color: var(--text-muted); text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 4px;">
          <span class="material-symbols-rounded" style="font-size: 18px;">arrow_back</span>
          Back to Home
        </a>
      </div>
    </form>
  </div>
</section>