<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <% } %>
  <title><%= typeof title !== 'undefined' ? title : 'E-Tracks' %></title>
  <link rel="icon" type="image/png" href="/assets/logo.png" />
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'E-Tracks - The ultimate learning management platform to master your skills with core-first education.' %>">
  <meta name="keywords" content="<%= typeof keywords !== 'undefined' ? keywords : 'education, learning, lms, e-tracks, courses, programming, design, skills' %>">
  <meta name="author" content="E-Tracks Team">
  <meta name="robots" content="index, follow">


  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://etracks.com<%= typeof path !== 'undefined' ? path : '' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'E-Tracks' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Master your track with E-Tracks.' %>">
  <meta property="og:image" content="https://etracks.com/assets/og-image.png">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://etracks.com<%= typeof path !== 'undefined' ? path : '' %>">
  <meta property="twitter:title" content="<%= title %>">
  <meta property="twitter:description" content="<%= typeof description !== 'undefined' ? description : 'Master your track with E-Tracks.' %>">
  <meta property="twitter:image" content="https://etracks.com/assets/og-image.png">

  <link rel="canonical" href="https://etracks.com<%= typeof path !== 'undefined' ? path : '' %>">

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=5.1" />
  <% if (typeof pageStyles !== 'undefined' && pageStyles) { %>
    <% pageStyles.forEach(style => { %>
      <link rel="stylesheet" href="<%= style %>?v=4.5" />
    <% }) %>
  <% } %>
</head>
<body data-auth="<%= typeof isLoggedIn !== 'undefined' ? isLoggedIn : false %>">
  <div class="global-bg-decorations">
    <div class="decor-blob decor-1"></div>
    <div class="decor-blob decor-2"></div>
    <div class="decor-half-circle"></div>
    <div class="decor-dots"></div>
  </div>

<% if (!(typeof hideHeaderFooter !== 'undefined' && hideHeaderFooter)) { %>
<%- include('partials/header', { isLoggedIn: typeof isLoggedIn !== 'undefined' ? isLoggedIn : false, userRole: typeof userRole !== 'undefined' ? userRole : '', navCourses: typeof navCourses !== 'undefined' ? navCourses : [] }) %>
<% } %>


  <main class="<%= typeof hideHeaderFooter !== 'undefined' && hideHeaderFooter ? 'main-fullscreen' : '' %>">
    <%- body %>
  </main>

  <% if (!(typeof hideHeaderFooter !== 'undefined' && hideHeaderFooter) && !(typeof hideFooter !== 'undefined' && hideFooter)) { %>
  <%- include('partials/footer') %>
  <% } %>

  <!-- Scroll To Top Button -->
  <button id="scrollToTopBtn" class="scroll-to-top" aria-label="Scroll to top">
    <span class="material-symbols-rounded">arrow_upward</span>
  </button>

  <script src="/js/alerts.js?v=4.5"></script>
  <script src="/js/toast.js?v=4.6" type="module"></script>
  <script src="/js/main.js?v=5.2" type="module"></script>
  <% if (typeof pageScripts !== 'undefined' && pageScripts) { %>
    <% pageScripts.forEach(script => { %>
      <% if (typeof script === 'string' && script.split('?')[0].endsWith('.js')) { %>
        <% const separator = script.includes('?') ? '&' : '?'; %>
        <script src="<%= script %><%= separator %>v=4.9" type="module"></script>
      <% } else { %>
        <% const separator = script.includes('?') ? '&' : '?'; %>
        <script src="<%= script %><%= separator %>v=4.5"></script>
      <% } %>
    <% }) %>
  <% } %>
</body>
</html>

